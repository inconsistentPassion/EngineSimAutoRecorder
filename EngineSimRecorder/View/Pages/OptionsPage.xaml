<Page x:Class="EngineSimRecorder.View.Pages.OptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:EngineSimRecorder.Helpers"
      ScrollViewer.CanContentScroll="False">


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  helpers:MouseWheelHelper.EnableForwarding="True">
        <StackPanel MinWidth="0" Margin="20,12,20,12">
            <TextBlock Text="Options" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="Configure recording settings" FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- Theme -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Theme:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <ComboBox x:Name="cmbTheme" Grid.Column="1" FontSize="12">
                            <ComboBoxItem Content="Dark" IsSelected="True" />
                            <ComboBoxItem Content="Light" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Profiles -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Profiles" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Save and load RPM target sets + output settings." FontSize="11" Opacity="0.5" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Load:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ComboBox x:Name="cmbProfiles" FontSize="12" HorizontalAlignment="Stretch" MinWidth="180" />
                            <ui:Button x:Name="btnLoadProfile" Content="Load" Appearance="Primary" FontSize="11" Margin="6,0,0,0" />
                            <ui:Button x:Name="btnDeleteProfile" Content="Delete" FontSize="11" Margin="3,0,0,0" />
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Save:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="txtProfileName" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Stretch" MinWidth="180" />
                            <ui:Button x:Name="btnSaveProfile" Content="Save" Appearance="Primary" FontSize="11" Margin="6,0,0,0" />
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="lblProfileStatus" FontSize="11" Opacity="0.5" Margin="0,6,0,0" />
                </StackPanel>
            </ui:Card>

            <!-- Audio Processing -->
            <Expander x:Name="expSound" Margin="0,0,0,8">
                <Expander.Header>
                    <StackPanel>
                        <TextBlock Text="Audio Processing" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Interior/Exterior DSP and recording mode" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel>
                    <TextBlock Text="Recording Mode" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Interior mode applies a filter to simulate cabin sound." FontSize="11" Opacity="0.5" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton x:Name="rbExterior" Content=" Exterior" IsChecked="True" GroupName="RecMode" FontSize="12" Margin="0,0,20,0" Opacity="0.6" />
                        <RadioButton x:Name="rbInterior" Content=" Interior" GroupName="RecMode" FontSize="12" Opacity="0.6" />
                    </StackPanel>

                    <!-- Exterior DSP Preset (shown when Exterior is selected) -->
                    <StackPanel x:Name="pnlExhaustPreset" Margin="0,10,0,0" Visibility="Visible">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Exhaust DSP:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <ComboBox x:Name="cmbExhaustPreset" Grid.Column="1" FontSize="12" SelectedIndex="0">
                                <ComboBoxItem Content="Raw (no processing)" IsSelected="True" />
                                <ComboBoxItem Content="Sport" />
                                <ComboBoxItem Content="Race" />
                                <ComboBoxItem Content="Supercar" />
                                <ComboBoxItem Content="Muffled / OEM" />
                                <ComboBoxItem Content="Custom" />
                            </ComboBox>
                        </Grid>
                        <TextBlock FontSize="11" Opacity="0.4" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Race/Sport/Supercar/Muffler apply EQ, saturation, reverb and compression. Raw outputs unmodified audio. Custom lets you tune every parameter." />

                        <!-- Custom exterior parameters (shown only when Custom is selected) -->
                        <Border x:Name="pnlCustomExterior" Visibility="Collapsed"
                                Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="12,10" Margin="0,10,0,0"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="EQ" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LP cutoff" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtLpHz" Grid.Column="1" Minimum="2000" Maximum="16000" Value="8000" TickFrequency="500" IsSnapToTickEnabled="True" SmallChange="500" LargeChange="2000" VerticalAlignment="Center"
                                            ToolTip="Air absorption simulation. Lowers the frequency where sound starts to fade out with distance." />
                                    <TextBlock x:Name="lblExtLpHz" Grid.Column="2" Text="8000 Hz" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LP Q" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtLpQ" Grid.Column="1" Minimum="0.3" Maximum="2.0" Value="0.7" TickFrequency="0.1" IsSnapToTickEnabled="True" SmallChange="0.1" LargeChange="0.5" VerticalAlignment="Center"
                                            ToolTip="Sharpness of the low-pass filter cutoff. Higher values add a slight resonance." />
                                    <TextBlock x:Name="lblExtLpQ" Grid.Column="2" Text="0.7" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hi-shelf Hz" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtHsHz" Grid.Column="1" Minimum="2000" Maximum="12000" Value="5000" TickFrequency="500" IsSnapToTickEnabled="True" SmallChange="500" LargeChange="2000" VerticalAlignment="Center"
                                            ToolTip="Natural high-frequency decay. Frequencies above this point are gradually reduced." />
                                    <TextBlock x:Name="lblExtHsHz" Grid.Column="2" Text="5000 Hz" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hi-shelf dB" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtHsGainDb" Grid.Column="1" Minimum="-12" Maximum="6" Value="-3" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="3" VerticalAlignment="Center"
                                            ToolTip="Intensity of high-frequency roll-off. Lower values sound darker and more distance-muted." />
                                    <TextBlock x:Name="lblExtHsGainDb" Grid.Column="2" Text="-3 dB" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Low-mid Hz" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtMidHz" Grid.Column="1" Minimum="60" Maximum="400" Value="150" TickFrequency="10" IsSnapToTickEnabled="True" SmallChange="10" LargeChange="50" VerticalAlignment="Center"
                                            ToolTip="Warmth EQ center frequency. Adjusts the 'body' and fullness of the exhaust note." />
                                    <TextBlock x:Name="lblExtMidHz" Grid.Column="2" Text="150 Hz" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Low-mid dB" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtMidGainDb" Grid.Column="1" Minimum="-6" Maximum="9" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="3" VerticalAlignment="Center"
                                            ToolTip="Boost or cut for the low-mid warmth. Adds punch and richness." />
                                    <TextBlock x:Name="lblExtMidGainDb" Grid.Column="2" Text="+3 dB" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <TextBlock Text="Saturation &amp; noise" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sat drive" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtSatDrive" Grid.Column="1" Minimum="1.0" Maximum="3.0" Value="1.4" TickFrequency="0.1" IsSnapToTickEnabled="True" SmallChange="0.1" LargeChange="0.5" VerticalAlignment="Center"
                                            ToolTip="Tape-style saturation intensity. Adds harmonic enrichment and warm distortion." />
                                    <TextBlock x:Name="lblExtSatDrive" Grid.Column="2" Text="1.4" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <CheckBox x:Name="chkExtNoise" Content=" Mechanical noise (not recommended - adds static)" FontSize="11" Opacity="0.4" IsChecked="False" Margin="0,0,0,8" />
                                <TextBlock Text="Reverb" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Rev ms" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtReverbMs" Grid.Column="1" Minimum="5" Maximum="80" Value="25" TickFrequency="5" IsSnapToTickEnabled="True" SmallChange="5" LargeChange="10" VerticalAlignment="Center"
                                            ToolTip="Multi-tap delay spacing. Simulates natural environment reflection timing." />
                                    <TextBlock x:Name="lblExtReverbMs" Grid.Column="2" Text="25 ms" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Reverb %" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtReverbMix" Grid.Column="1" Minimum="0" Maximum="30" Value="10" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="5" VerticalAlignment="Center"
                                            ToolTip="Dry/Wet mix for the exterior space simulation." />
                                    <TextBlock x:Name="lblExtReverbMix" Grid.Column="2" Text="10%" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <TextBlock Text="Dynamics" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Comp ratio" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtCompRatio" Grid.Column="1" Minimum="1" Maximum="8" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="2" VerticalAlignment="Center"
                                            ToolTip="Dynamics compression ratio. Higher values even out volume peaks for consistency." />
                                    <TextBlock x:Name="lblExtCompRatio" Grid.Column="2" Text="3:1" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Threshold" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slExtCompThresh" Grid.Column="1" Minimum="-24" Maximum="0" Value="-12" TickFrequency="2" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="6" VerticalAlignment="Center"
                                            ToolTip="Compression threshold. Audio above this level (in dB) will be compressed." />
                                    <TextBlock x:Name="lblExtCompThresh" Grid.Column="2" Text="-12 dB" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Interior DSP (shown when Interior is selected) -->
                    <StackPanel x:Name="pnlCutoff" Margin="0,10,0,0" Visibility="Collapsed">
                        <Grid VerticalAlignment="Center" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Car type:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <ComboBox x:Name="cmbCarType" Grid.Column="1" FontSize="12">
                                <ComboBoxItem Content="Sedan" IsSelected="True" />
                                <ComboBoxItem Content="Coupe" />
                                <ComboBoxItem Content="SUV" />
                                <ComboBoxItem Content="Hatchback" />
                                <ComboBoxItem Content="Supercar" />
                                <ComboBoxItem Content="Truck" />
                                <ComboBoxItem Content="Custom" />
                            </ComboBox>
                        </Grid>
                        <Border x:Name="pnlCustom" Visibility="Collapsed"
                                Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="12,10" Margin="0,10,0,0"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Cabin acoustics" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LP cutoff" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slCutoff" Grid.Column="1" Minimum="1000" Maximum="4000" Value="2000" TickFrequency="100" IsSnapToTickEnabled="True" SmallChange="100" LargeChange="500" VerticalAlignment="Center"
                                            ToolTip="Car cabin insulation simulation. Higher values allow more engine detail; lower values sound more muffled." />
                                    <TextBlock x:Name="lblCutoff" Grid.Column="2" Text="2000 Hz" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Rumble Hz" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRumbleHz" Grid.Column="1" Minimum="40" Maximum="120" Value="80" TickFrequency="5" IsSnapToTickEnabled="True" SmallChange="5" LargeChange="20" VerticalAlignment="Center"
                                            ToolTip="Structure-borne rumble frequency. Simulates vibrations transmitted through the chassis." />
                                    <TextBlock x:Name="lblRumbleHz" Grid.Column="2" Text="80 Hz" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Rumble dB" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRumbleDb" Grid.Column="1" Minimum="0" Maximum="12" Value="6" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="3" VerticalAlignment="Center"
                                            ToolTip="Intensity of the low-frequency rumble boost." />
                                    <TextBlock x:Name="lblRumbleDb" Grid.Column="2" Text="+6 dB" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Res 1 Hz" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes1Hz" Grid.Column="1" Minimum="100" Maximum="300" Value="180" TickFrequency="10" IsSnapToTickEnabled="True" SmallChange="10" LargeChange="50" VerticalAlignment="Center"
                                            ToolTip="Primary cabin resonance frequency. Simulates the natural frequency of the enclosed space." />
                                    <TextBlock x:Name="lblRes1Hz" Grid.Column="2" Text="180 Hz" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Res 1 dB" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes1Db" Grid.Column="1" Minimum="0" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="2" VerticalAlignment="Center"
                                            ToolTip="Intensity of the primary (lower) cabin resonance boost." />
                                    <TextBlock x:Name="lblRes1Db" Grid.Column="2" Text="+5 dB" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Res 2 Hz" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes2Hz" Grid.Column="1" Minimum="200" Maximum="500" Value="350" TickFrequency="10" IsSnapToTickEnabled="True" SmallChange="10" LargeChange="50" VerticalAlignment="Center"
                                            ToolTip="Secondary cabin resonance frequency. Simulates higher-order reflections in the car interior." />
                                    <TextBlock x:Name="lblRes2Hz" Grid.Column="2" Text="350 Hz" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Res 2 dB" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes2Db" Grid.Column="1" Minimum="0" Maximum="8" Value="4" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="2" VerticalAlignment="Center"
                                            ToolTip="Intensity of the secondary (higher) cabin resonance boost." />
                                    <TextBlock x:Name="lblRes2Db" Grid.Column="2" Text="+4 dB" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <TextBlock Text="Stereo &amp; reverb" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Width %" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slWidth" Grid.Column="1" Minimum="10" Maximum="100" Value="30" TickFrequency="5" IsSnapToTickEnabled="True" SmallChange="5" LargeChange="20" VerticalAlignment="Center"
                                            ToolTip="Stereo width narrowing. Lower percentages simulate sound coming from specific locations (e.g. firewall)." />
                                    <TextBlock x:Name="lblWidth" Grid.Column="2" Text="30%" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Reverb %" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slReverbMix" Grid.Column="1" Minimum="0" Maximum="20" Value="7" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="5" VerticalAlignment="Center"
                                            ToolTip="Dry/Wet mix for the short cabin reverb simulation." />
                                    <TextBlock x:Name="lblReverbMix" Grid.Column="2" Text="7%" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Rev ms" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slReverbMs" Grid.Column="1" Minimum="10" Maximum="80" Value="30" TickFrequency="5" IsSnapToTickEnabled="True" SmallChange="5" LargeChange="10" VerticalAlignment="Center"
                                            ToolTip="Cabin reverb delay. Simulates the small physical space of the interior." />
                                    <TextBlock x:Name="lblReverbMs" Grid.Column="2" Text="30 ms" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <TextBlock Text="Dynamics" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,8" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Comp ratio" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slCompRatio" Grid.Column="1" Minimum="1" Maximum="8" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="2" VerticalAlignment="Center"
                                            ToolTip="Dynamics compression ratio. Higher values result in more aggressive volume limiting." />
                                    <TextBlock x:Name="lblCompRatio" Grid.Column="2" Text="3:1" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Threshold" Grid.Column="0" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slCompThresh" Grid.Column="1" Minimum="-24" Maximum="0" Value="-12" TickFrequency="2" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="6" VerticalAlignment="Center"
                                            ToolTip="Compression threshold. Sets the level (in dB) above which the compressor activates." />
                                    <TextBlock x:Name="lblCompThresh" Grid.Column="2" Text="-12 dB" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock x:Name="lblAdvancedEmpty" Text="No processing applied in Raw mode." 
                               FontSize="11" Opacity="0.4" HorizontalAlignment="Center" Margin="0,20" Visibility="Collapsed" />
                </StackPanel>
            </Expander>

            <!-- Audio Quality -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Audio Quality" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Sample Rate:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <ComboBox x:Name="cmbSampleRate" Grid.Row="0" Grid.Column="1" Width="180" HorizontalAlignment="Left" FontSize="12">
                            <ComboBoxItem Content="44100 Hz" IsSelected="True" />
                            <ComboBoxItem Content="48000 Hz" />
                        </ComboBox>

                        <TextBlock Text="Channels:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <ComboBox x:Name="cmbChannels" Grid.Row="2" Grid.Column="1" Width="180" HorizontalAlignment="Left" FontSize="12">
                            <ComboBoxItem Content="Stereo" IsSelected="True" />
                            <ComboBoxItem Content="Mono" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Extras -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Extras" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <CheckBox x:Name="chkRecordLimiter" Content=" Record engine limiter sound" FontSize="12" Opacity="0.6" Margin="0,0,0,4" />
                    <TextBlock FontSize="11" Opacity="0.5" Margin="0,0,0,8" Text="Records throttle held at rev limiter as engine_limiter.wav" />
                    <CheckBox x:Name="chkGeneratePowerLut" Content=" Generate power.lut" FontSize="12" Opacity="0.6" Margin="0,0,0,4" />
                    <TextBlock Text="Reads torque at each RPM target" FontSize="11" Opacity="0.5" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
