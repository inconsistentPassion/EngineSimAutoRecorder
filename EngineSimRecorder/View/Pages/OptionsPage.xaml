<Page x:Class="EngineSimRecorder.View.Pages.OptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,12,20,12">
        <StackPanel MinWidth="0">
            <TextBlock Text="Options" FontSize="20" FontWeight="Bold" Margin="0,0,0,2" />
            <TextBlock Text="Configure recording settings" FontSize="12" Opacity="0.6" Margin="0,0,0,12" />

            <!-- Theme -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Theme:" VerticalAlignment="Center" FontSize="12" Opacity="0.6" Margin="0,0,8,0" />
                        <ComboBox x:Name="cmbTheme" Width="140" FontSize="12">
                            <ComboBoxItem Content="Dark" IsSelected="True" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="System" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Profiles -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Profiles" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Save and load RPM target sets + output settings." FontSize="11" Opacity="0.5" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Load:" VerticalAlignment="Center" FontSize="12" Opacity="0.6" Margin="0,0,8,0" />
                        <ComboBox x:Name="cmbProfiles" Width="200" FontSize="12" />
                        <ui:Button x:Name="btnLoadProfile" Content="Load" Appearance="Primary" FontSize="11" Margin="6,0,0,0" />
                        <ui:Button x:Name="btnDeleteProfile" Content="Delete" FontSize="11" Margin="3,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Save:" VerticalAlignment="Center" FontSize="12" Opacity="0.6" Margin="0,0,8,0" />
                        <TextBox x:Name="txtProfileName" Width="200" FontSize="12" VerticalAlignment="Center" />
                        <ui:Button x:Name="btnSaveProfile" Content="Save" Appearance="Primary" FontSize="11" Margin="6,0,0,0" Width="50" />
                    </StackPanel>
                    <TextBlock x:Name="lblProfileStatus" FontSize="11" Opacity="0.5" Margin="0,6,0,0" />
                </StackPanel>
            </ui:Card>

            <!-- Recording Mode -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Recording Mode" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Interior mode applies a filter to simulate cabin sound." FontSize="11" Opacity="0.5" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton x:Name="rbExterior" Content=" Exterior" IsChecked="True" GroupName="RecMode" FontSize="12" Margin="0,0,20,0" Opacity="0.6" />
                        <RadioButton x:Name="rbInterior" Content=" Interior" GroupName="RecMode" FontSize="12" Opacity="0.6" />
                    </StackPanel>
                    <StackPanel x:Name="pnlCutoff" Margin="0,10,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Car type:" VerticalAlignment="Center" FontSize="12" Opacity="0.6" Margin="0,0,6,0" />
                            <ComboBox x:Name="cmbCarType" Width="140" FontSize="12">
                                <ComboBoxItem Content="Sedan" IsSelected="True" />
                                <ComboBoxItem Content="Coupe" />
                                <ComboBoxItem Content="SUV" />
                                <ComboBoxItem Content="Hatchback" />
                                <ComboBoxItem Content="Supercar" />
                                <ComboBoxItem Content="Truck" />
                                <ComboBoxItem Content="Custom" />
                            </ComboBox>
                        </StackPanel>
                        <Border x:Name="pnlCustom" Visibility="Collapsed"
                                Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="12,10" Margin="0,10,0,0"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Cabin acoustics" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="LP cutoff" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slCutoff" Minimum="1000" Maximum="4000" Value="2000" Width="140" TickFrequency="100" IsSnapToTickEnabled="True" SmallChange="100" LargeChange="500" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblCutoff" Text="2000 Hz" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Rumble Hz" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRumbleHz" Minimum="40" Maximum="120" Value="80" Width="140" TickFrequency="5" IsSnapToTickEnabled="True" SmallChange="5" LargeChange="20" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblRumbleHz" Text="80 Hz" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Rumble dB" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRumbleDb" Minimum="0" Maximum="12" Value="6" Width="140" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="3" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblRumbleDb" Text="+6 dB" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Res 1 Hz" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes1Hz" Minimum="100" Maximum="300" Value="180" Width="140" TickFrequency="10" IsSnapToTickEnabled="True" SmallChange="10" LargeChange="50" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblRes1Hz" Text="180 Hz" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Res 1 dB" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes1Db" Minimum="0" Maximum="10" Value="5" Width="140" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="2" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblRes1Db" Text="+5 dB" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Res 2 Hz" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes2Hz" Minimum="200" Maximum="500" Value="350" Width="140" TickFrequency="10" IsSnapToTickEnabled="True" SmallChange="10" LargeChange="50" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblRes2Hz" Text="350 Hz" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Res 2 dB" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slRes2Db" Minimum="0" Maximum="8" Value="4" Width="140" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="2" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblRes2Db" Text="+4 dB" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <TextBlock Text="Stereo &amp; reverb" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Width %" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slWidth" Minimum="10" Maximum="100" Value="30" Width="140" TickFrequency="5" IsSnapToTickEnabled="True" SmallChange="5" LargeChange="20" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblWidth" Text="30%" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Reverb %" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slReverbMix" Minimum="0" Maximum="20" Value="7" Width="140" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="5" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblReverbMix" Text="7%" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Rev ms" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slReverbMs" Minimum="10" Maximum="80" Value="30" Width="140" TickFrequency="5" IsSnapToTickEnabled="True" SmallChange="5" LargeChange="10" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblReverbMs" Text="30 ms" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <TextBlock Text="Dynamics" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Comp ratio" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slCompRatio" Minimum="1" Maximum="8" Value="3" Width="140" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="2" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblCompRatio" Text="3:1" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Threshold" Width="80" FontSize="11" VerticalAlignment="Center" Opacity="0.6" />
                                    <Slider x:Name="slCompThresh" Minimum="-24" Maximum="0" Value="-12" Width="140" TickFrequency="2" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="6" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lblCompThresh" Text="-12 dB" Width="60" FontSize="11" VerticalAlignment="Center" Opacity="0.5" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Audio Quality -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Audio Quality" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Sample Rate:" VerticalAlignment="Center" FontSize="12" Opacity="0.6" Margin="0,0,6,0" />
                        <ComboBox x:Name="cmbSampleRate" Width="120" FontSize="12" Margin="0,0,20,0">
                            <ComboBoxItem Content="44100 Hz" IsSelected="True" />
                            <ComboBoxItem Content="48000 Hz" />
                        </ComboBox>
                        <TextBlock Text="Channels:" VerticalAlignment="Center" FontSize="12" Opacity="0.6" Margin="0,0,6,0" />
                        <ComboBox x:Name="cmbChannels" Width="100" FontSize="12">
                            <ComboBoxItem Content="Stereo" IsSelected="True" />
                            <ComboBoxItem Content="Mono" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Extras -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Extras" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <CheckBox x:Name="chkRecordLimiter" Content=" Record engine limiter sound" FontSize="12" Opacity="0.6" Margin="0,0,0,4" />
                    <TextBlock FontSize="11" Opacity="0.5" Margin="0,0,0,8" Text="Records throttle held at rev limiter as engine_limiter.wav" />
                    <CheckBox x:Name="chkGeneratePowerLut" Content=" Generate power.lut" FontSize="12" Opacity="0.6" Margin="0,0,0,4" />
                    <TextBlock Text="Reads torque at each RPM target" FontSize="11" Opacity="0.5" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
