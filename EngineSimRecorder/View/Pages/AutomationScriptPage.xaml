<Page x:Class="EngineSimRecorder.View.Pages.AutomationScriptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:EngineSimRecorder.Helpers"
      ScrollViewer.CanContentScroll="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="20,12,20,0"
                      helpers:MouseWheelHelper.EnableForwarding="True"
                      ScrollViewer.PanningMode="VerticalOnly"
                      ScrollViewer.CanContentScroll="False">
            <StackPanel MinWidth="0">

                <TextBlock Text="Execution" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Part 2 — Generate JavaScript, ES3 validation, run in FMOD Studio"
                           FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Generated script" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Border Background="#10101A" CornerRadius="6" Padding="12,10">
                            <TextBox x:Name="txtJsCode"
                                     FontFamily="Consolas" FontSize="11"
                                     Foreground="#D4D4D4" Background="Transparent"
                                     BorderThickness="0"
                                     TextWrapping="NoWrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     MinHeight="160" MaxHeight="280"
                                     IsReadOnly="True" />
                        </Border>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Activity log" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ui:Button x:Name="btnCopyLog" Grid.Column="1" Content="Copy" FontSize="11" Margin="0,0,6,0" />
                            <ui:Button x:Name="btnClearLog" Grid.Column="2" Content="Clear" FontSize="11" />
                        </Grid>
                        <ProgressBar x:Name="pbar" Height="5" Margin="0,0,0,8" Minimum="0" Maximum="100" Value="0" />
                        <Border Background="#10101A" CornerRadius="6" Padding="10,8" MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="txtLog"
                                         FontFamily="Consolas" FontSize="11"
                                         Foreground="#57F287" Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </ScrollViewer>
                        </Border>

                        <Border x:Name="borderViolations" Visibility="Collapsed"
                                Background="#20FFCC00" BorderBrush="#40FFCC00" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="JavaScript compatibility (ES3)" FontSize="11" FontWeight="Bold" Foreground="#FFCC00" Margin="0,0,0,2" />
                                <TextBlock x:Name="lblViolations" FontSize="11" Foreground="#FFCC00" TextWrapping="Wrap" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="borderResult" Visibility="Collapsed"
                                CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                            <TextBlock x:Name="lblResult" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Padding="20,8,20,8" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:Button x:Name="btnGenerate" Content="Generate Script" Appearance="Secondary" FontSize="13" Padding="16,8" Margin="0,0,8,0" />
                    <ui:Button x:Name="btnRun" Content="Run Automation" Appearance="Primary" FontSize="13" Padding="16,8" />
                </StackPanel>
                <TextBlock x:Name="lblStage" Grid.Column="1" VerticalAlignment="Center" FontSize="11" Opacity="0.5" Margin="12,0,0,0" TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Page>
