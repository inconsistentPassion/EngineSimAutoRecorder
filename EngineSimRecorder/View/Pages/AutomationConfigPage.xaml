<Page x:Class="EngineSimRecorder.View.Pages.AutomationConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:EngineSimRecorder.Helpers"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="20,12,20,12"
                  helpers:MouseWheelHelper.EnableForwarding="True"
                  ScrollViewer.PanningMode="VerticalOnly"
                  ScrollViewer.CanContentScroll="False">
        <StackPanel MinWidth="0">

            <TextBlock Text="Workspace" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="Part 1 — Car name, paths, FMOD connection, and generation mode"
                       FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FMOD Studio" FontSize="14" FontWeight="SemiBold" Grid.Column="0" />
                        <Border x:Name="borderConnStatus" Grid.Column="1"
                                Background="#40FF4040" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock x:Name="lblConnStatus" Text="Disconnected" FontSize="10"
                                       FontWeight="SemiBold" Foreground="#FF8080" />
                        </Border>
                    </Grid>
                    <TextBlock FontSize="11" Opacity="0.5" Margin="0,0,0,8" TextWrapping="Wrap"
                               Text="Open FMOD Studio with a project loaded. TCP port 3663." />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="lblConnDetail" Grid.Column="0" FontSize="11" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button x:Name="btnConnect" Content="Connect" Appearance="Primary" FontSize="12" Margin="0,0,6,0" />
                            <ui:Button x:Name="btnDisconnect" Content="Disconnect" FontSize="12" IsEnabled="False" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Project paths" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Car Name:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <TextBox x:Name="txtCarName" Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                                 ToolTip="Matches WAV prefix and AC car folder (e.g. fa01)" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" MinWidth="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FMOD Project:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <TextBox x:Name="txtFmodProject" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        <ui:Button x:Name="btnBrowseFmod" Grid.Column="2" Content="Browse" FontSize="12" Margin="8,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" MinWidth="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Exterior" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <TextBox x:Name="txtRecordingsDir" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        <ui:Button x:Name="btnBrowseRecordings" Grid.Column="2" Content="Browse" FontSize="12" Margin="8,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" MinWidth="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Interior (WIP)" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <TextBox x:Name="txtRecordingsDirInt" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        <ui:Button x:Name="btnBrowseRecordingsInt" Grid.Column="2" Content="Browse" FontSize="12" Margin="8,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" MinWidth="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Limiter (WIP)" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <TextBox x:Name="txtRecordingsDirLimiter" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        <ui:Button x:Name="btnBrowseRecordingsLimiter" Grid.Column="2" Content="Browse" FontSize="12" Margin="8,0,0,0" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" MinWidth="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="AC Content:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <TextBox x:Name="txtAcContent" Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                                 ToolTip="Assetto Corsa content\ root" />
                        <ui:Button x:Name="btnBrowseAc" Grid.Column="2" Content="Browse" FontSize="12" Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Generation mode" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Strategy:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                        <ComboBox x:Name="cmbGenerationMode" Grid.Column="1" FontSize="12">
                            <ComboBoxItem Content="Update Assetto Corsa Template (Recommended)" IsSelected="True" />
                            <ComboBoxItem Content="Custom (from scratch)" />
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="chkCopyArtifacts" Content="Copy GUIDs.txt and .bank to AC sfx after build"
                              FontSize="12" IsChecked="True" />
                    <TextBlock FontSize="11" Opacity="0.55" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="In Template mode the car name is fixed to fa01 and AC copy is disabled. Use Custom for your own car folder and deployment." />
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
