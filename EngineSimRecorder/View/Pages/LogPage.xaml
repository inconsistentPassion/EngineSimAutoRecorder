<Page x:Class="EngineSimRecorder.View.Pages.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="20,12,20,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title and Toolbar -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Log Output" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <StackPanel Orientation="Horizontal">
                <ui:Button x:Name="btnCopyLog" Content="Copy to Clipboard" FontSize="11" Margin="0,0,6,0" />
                <ui:Button x:Name="btnClearLog" Content="Clear Log" FontSize="11" Appearance="Danger" />
            </StackPanel>
        </StackPanel>

        <!-- Log Text Area -->
        <Border Grid.Row="1" Background="#18181C" CornerRadius="8" Padding="14,10">
            <TextBox x:Name="txtLog" FontFamily="Silkscreen, Cascadia Mono" FontSize="12"
                     Foreground="#57F287" Background="Transparent" BorderThickness="0"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </Border>
    </Grid>
</Page>
