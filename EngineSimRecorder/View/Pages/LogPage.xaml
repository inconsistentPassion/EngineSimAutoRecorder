<Page x:Class="EngineSimRecorder.View.Pages.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      HorizontalContentAlignment="Stretch">

    <Grid Margin="20,12,20,12">
        <Border Background="#18181C" CornerRadius="8" Padding="14,10">
            <TextBox x:Name="txtLog" FontFamily="Cascadia Mono" FontSize="12"
                     Foreground="#57F287" Background="Transparent" BorderThickness="0"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </Border>
    </Grid>
</Page>
