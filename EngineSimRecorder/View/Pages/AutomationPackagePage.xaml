<Page x:Class="EngineSimRecorder.View.Pages.AutomationPackagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:EngineSimRecorder.Helpers"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="20,12,20,12"
                  helpers:MouseWheelHelper.EnableForwarding="True"
                  ScrollViewer.PanningMode="VerticalOnly"
                  ScrollViewer.CanContentScroll="False">
        <StackPanel MinWidth="0">

            <TextBlock Text="Deployment" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="Part 3 — Build outputs, copy to Assetto Corsa, open folders"
                       FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Automatic Deploy" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Build all banks in FMOD Studio and copy outputs to Assetto Corsa in one click." FontSize="11" Opacity="0.55" Margin="0,0,0,12" TextWrapping="Wrap" />
                    <ui:Button x:Name="btnBuildAndDeploy" Content="Build &amp; Deploy" Appearance="Primary" FontSize="13" Padding="20,10" HorizontalAlignment="Left" />
                    <ProgressBar x:Name="pbarDeploy" Height="4" Margin="0,12,0,4" Visibility="Collapsed" IsIndeterminate="True" />
                    <TextBlock x:Name="lblDeployStatus" FontSize="11" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Manual deploy" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Run only the post-build copy (no FMOD script). Requires FMOD project and AC paths on Workspace, and a built .bank in Build." FontSize="11" Opacity="0.55" Margin="0,0,0,8" TextWrapping="Wrap" />
                    <ui:Button x:Name="btnCopyArtifactsOnly" Content="Copy artifacts only" Appearance="Secondary" FontSize="12" HorizontalAlignment="Left" />
                    <TextBlock x:Name="lblCopyOnlyResult" FontSize="11" Opacity="0.65" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Open in Explorer" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <WrapPanel Orientation="Horizontal">
                        <ui:Button x:Name="btnOpenFmodBuild" Content="FMOD Build" FontSize="12" Margin="0,0,8,8" />
                        <ui:Button x:Name="btnOpenAcSfx" Content="AC car sfx" FontSize="12" Margin="0,0,8,8" />
                        <ui:Button x:Name="btnOpenRecordingsExt" Content="Exterior recordings" FontSize="12" Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
