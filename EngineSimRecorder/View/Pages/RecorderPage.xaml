<Page x:Class="EngineSimRecorder.View.Pages.RecorderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
     
     >

    <Grid Margin="20,12,20,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2" Text="ES Recorder" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12" Text="Smart engine audio capture for Assetto Corsa" />

                <!-- Process -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Process" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Target:" Grid.Column="0" VerticalAlignment="Center" Opacity="0.6" FontSize="12" Margin="0,0,8,0" />
                            <ComboBox x:Name="cmbProcess" Grid.Column="1" IsEditable="False" VerticalAlignment="Center" FontSize="12" />
                            <ui:Button x:Name="btnConnect" Grid.Column="2" Content="Connect" Appearance="Primary" Margin="8,0,0,0" FontSize="12" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Output -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Output" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Directory:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtOutputDir" Grid.Column="1" Text="recordings" VerticalAlignment="Center" FontSize="12" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                <ui:Button x:Name="btnBrowse" Content="Browse" FontSize="11" />
                                <ui:Button x:Name="btnOpenFolder" Content="Open" Margin="4,0,0,0" FontSize="11" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Car Name:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtCarName" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Text="Prefix:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtPrefix" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- RPM Targets -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="RPM Targets" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock x:Name="lblRedline" FontSize="11" Opacity="0.5" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Quick:" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.5" FontSize="11" />
                            <ui:Button Content="1K" FontSize="11" Padding="10,4" Tag="1000" />
                            <ui:Button Content="2K" FontSize="11" Padding="10,4" Tag="2000" Margin="3,0,0,0" />
                            <ui:Button Content="3K" FontSize="11" Padding="10,4" Tag="3000" Margin="3,0,0,0" />
                            <ui:Button Content="4K" FontSize="11" Padding="10,4" Tag="4000" Margin="3,0,0,0" />
                            <ui:Button Content="5K" FontSize="11" Padding="10,4" Tag="5000" Margin="3,0,0,0" />
                            <ui:Button Content="6K" FontSize="11" Padding="10,4" Tag="6000" Margin="3,0,0,0" />
                            <ui:Button Content="7K" FontSize="11" Padding="10,4" Tag="7000" Margin="3,0,0,0" />
                            <ui:Button Content="8K" FontSize="11" Padding="10,4" Tag="8000" Margin="3,0,0,0" />
                            <ui:Button Content="9K" FontSize="11" Padding="10,4" Tag="9000" Margin="3,0,0,0" />
                            <ui:Button Content="10K" FontSize="11" Padding="10,4" Tag="10000" Margin="3,0,0,0" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="lstRpm" Grid.Column="0" FontFamily="Consolas" FontSize="11" MaxHeight="160" />
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="Quick Edit" FontSize="10" Opacity="0.5" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button x:Name="btnNudgeDown" Content="-250" FontSize="11" Width="60" />
                                    <ui:Button x:Name="btnNudgeUp" Content="+250" FontSize="11" Margin="3,0,0,0" Width="60" />
                                    <ui:Button x:Name="btnAuto" Content="Auto" FontSize="11" Margin="3,0,0,0" Width="60" />
                                </StackPanel>
                                <TextBlock Text="RPM value" FontSize="10" Opacity="0.5" Margin="0,10,0,4" />
                                <TextBox x:Name="txtRpm" Text="1000" Width="186" FontFamily="Consolas" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <ui:Button x:Name="btnAdd" Content="Add" Appearance="Primary" FontSize="11" Width="92" />
                                    <ui:Button x:Name="btnEdit" Content="Edit" FontSize="11" Margin="3,0,0,0" Width="91" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <ui:Button x:Name="btnRemove" Content="Remove" FontSize="11" Width="92" />
                                    <ui:Button x:Name="btnSort" Content="Sort" FontSize="11" Margin="3,0,0,0" Width="91" />
                                </StackPanel>
                                <ui:Button x:Name="btnClear" Content="Clear All" FontSize="11" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Status -->
                <ui:Card>
                    <StackPanel>
                        <TextBlock Text="Status" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock x:Name="lblStatus" Text="Idle..." VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="lblEta" VerticalAlignment="Center" FontSize="11" Opacity="0.5" Margin="0,0,8,0" />
                                <TextBlock x:Name="lblRpm" Text="RPM: ---" FontFamily="Consolas" FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                        <ProgressBar x:Name="pbar" Height="5" Margin="0,6,0,0" Minimum="0" Maximum="1" Value="0" />
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
            <ui:Button x:Name="btnStart" Content="Start" Appearance="Success" FontSize="15" Padding="24,10" />
            <ui:Button x:Name="btnStop" Content="Stop" Appearance="Danger" FontSize="15" Padding="24,10" Margin="10,0,0,0" IsEnabled="False" />
            <CheckBox x:Name="chkTop" Content=" Stay on Top" VerticalAlignment="Center" Margin="180,0,0,0" Opacity="0.6" />
        </StackPanel>
    </Grid>
</Page>
