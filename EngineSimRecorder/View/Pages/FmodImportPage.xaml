<Page x:Class="EngineSimRecorder.View.Pages.FmodImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:EngineSimRecorder.Helpers"
      ScrollViewer.CanContentScroll="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="20,12,20,0"
                      helpers:MouseWheelHelper.EnableForwarding="True"
                      ScrollViewer.PanningMode="VerticalOnly"
                      ScrollViewer.CanContentScroll="False">
            <StackPanel MinWidth="0">

                <!-- Header -->
                <TextBlock Text="FMOD TCP Import" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Send JavaScript directly to FMOD Studio via TCP and build banks for Assetto Corsa"
                           FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <!-- Connection Status -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Connection" FontSize="14" FontWeight="SemiBold" Grid.Column="0" />
                            <!-- Status dot -->
                            <Border x:Name="borderConnStatus" Grid.Column="1"
                                    Background="#40FF4040" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                <TextBlock x:Name="lblConnStatus" Text="Disconnected" FontSize="10"
                                           FontWeight="SemiBold" Foreground="#FF8080" />
                            </Border>
                        </Grid>
                        <TextBlock FontSize="11" Opacity="0.5" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="FMOD Studio must be open with a project loaded before connecting. TCP port 3663 is used." />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="lblConnDetail" Grid.Column="0" FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" />
                            <ui:Button x:Name="btnConnect" Grid.Column="1" Content="Connect" Appearance="Primary"
                                       FontSize="12" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Car Name + Paths -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Project Settings" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <!-- Car Name -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Car Name:" Grid.Column="0" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtCarName" Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="12" ToolTip="Matches the WAV prefix and AC car folder name (e.g. fa01)" />
                        </Grid>

                        <!-- FMOD Project dir -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FMOD Project:" Grid.Column="0" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtFmodProject" Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="12" ToolTip="Folder containing the .fspro file" />
                            <ui:Button x:Name="btnBrowseFmod" Grid.Column="2" Content="Browse"
                                       FontSize="12" Margin="8,0,0,0" />
                        </Grid>

                        <!-- WAV EXT recordings dir -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="EXT Recordings:" Grid.Column="0" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtRecordingsDir" Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="12" ToolTip="Folder with exterior .wav recordings (Engine EXT)" />
                            <ui:Button x:Name="btnBrowseRecordings" Grid.Column="2" Content="Browse"
                                       FontSize="12" Margin="8,0,0,0" />
                        </Grid>

                        <!-- WAV INT recordings dir -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="INT Recordings:" Grid.Column="0" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtRecordingsDirInt" Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="12" ToolTip="Folder with interior .wav recordings (Engine INT). Leave empty to skip." />
                            <ui:Button x:Name="btnBrowseRecordingsInt" Grid.Column="2" Content="Browse"
                                       FontSize="12" Margin="8,0,0,0" />
                        </Grid>

                        <!-- Limiter recordings dir -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Limiter Dir:" Grid.Column="0" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtRecordingsDirLimiter" Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="12" ToolTip="Folder with engine_limiter.wav (Accessories). Falls back to EXT dir if empty." />
                            <ui:Button x:Name="btnBrowseRecordingsLimiter" Grid.Column="2" Content="Browse"
                                       FontSize="12" Margin="8,0,0,0" />
                        </Grid>

                        <!-- AC content dir -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="AC Content:" Grid.Column="0" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtAcContent" Grid.Column="1" VerticalAlignment="Center"
                                     FontSize="12" ToolTip="Assetto Corsa content\ root folder" />
                            <ui:Button x:Name="btnBrowseAc" Grid.Column="2" Content="Browse"
                                       FontSize="12" Margin="8,0,0,0" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Generation Settings -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Automation Settings" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Strategy:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <ComboBox x:Name="cmbGenerationMode" Grid.Column="1" FontSize="12">
                                <ComboBoxItem Content="Update Assetto Corsa Template (Recommended)" IsSelected="True" ToolTip="Finds engine_ext/engine_int and replaces audio files."/>
                                <ComboBoxItem Content="Custom" ToolTip="Creates events and parameter routing from using your script."/>
                            </ComboBox>
                        </Grid>
                        
                        <Expander Header="Preview Generated Script" IsExpanded="False" Background="Transparent" Padding="0" Margin="0,4,0,0" BorderThickness="0">
                            <Border Background="#10101A" CornerRadius="6" Padding="12,10" Margin="0,8,0,0">
                                <TextBox x:Name="txtJsCode"
                                         FontFamily="Consolas" FontSize="11"
                                         Foreground="#D4D4D4" Background="Transparent"
                                         BorderThickness="0"
                                         TextWrapping="NoWrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         MinHeight="120" MaxHeight="200"
                                         IsReadOnly="True" />
                            </Border>
                        </Expander>
                    </StackPanel>
                </ui:Card>

                <!-- Post-Build Options -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Post-Build" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <CheckBox x:Name="chkCopyArtifacts" Content=" Copy GUIDs.txt and .bank to AC sfx folder after build"
                                  FontSize="12" IsChecked="True" />
                        <TextBlock FontSize="11" Opacity="0.55" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="When checked, the tool will automatically copy the final .bank and GUIDs.txt into your car's sfx folder after the build — no manual file moving needed. Requires the AC Content path to be set." />
                        <TextBlock FontSize="11" Opacity="0.4" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="If you prefer to move the files yourself, uncheck this box and leave the AC Content field empty. The FMOD project will still be updated and built." />
                    </StackPanel>
                </ui:Card>

                <!-- Progress / Log -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Progress" FontSize="14" FontWeight="SemiBold"
                                       Grid.Column="0" VerticalAlignment="Center" />
                            <ui:Button x:Name="btnCopyLog" Grid.Column="1" Content="Copy"
                                       FontSize="11" Margin="0,0,6,0"
                                       ToolTip="Copy full log to clipboard" />
                            <ui:Button x:Name="btnClearLog" Grid.Column="2" Content="Clear"
                                       FontSize="11" />
                        </Grid>

                        <ProgressBar x:Name="pbar" Height="5" Margin="0,0,0,8"
                                     Minimum="0" Maximum="100" Value="0" />

                        <Border Background="#10101A" CornerRadius="6" Padding="10,8" MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="txtLog"
                                         FontFamily="Silkscreen" FontSize="11"
                                         Foreground="#57F287" Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </ScrollViewer>
                        </Border>

                        <!-- Violations badge -->
                        <Border x:Name="borderViolations" Visibility="Collapsed"
                                Background="#20FFCC00" BorderBrush="#40FFCC00" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="JavaScript Compatibility Warnings" FontSize="11" FontWeight="Bold" Foreground="#FFCC00" Margin="0,0,0,2"/>
                                <TextBlock x:Name="lblViolations" FontSize="11" Foreground="#FFCC00" TextWrapping="Wrap" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <!-- Result badge -->
                        <Border x:Name="borderResult" Visibility="Collapsed"
                                CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                            <TextBlock x:Name="lblResult" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom action bar -->
        <Border Grid.Row="1" Padding="20,8,20,8" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:Button x:Name="btnRun" Content="Run Import" Appearance="Primary"
                               FontSize="14" Padding="20,8" IsEnabled="False" />
                    <ui:Button x:Name="btnCopyArtifactsOnly" Content="Copy Artifacts Only"
                               FontSize="12" Padding="14,8" Margin="8,0,0,0" IsEnabled="False"
                               ToolTip="Skip JS execution — only run the post-build copy step" />
                </StackPanel>
                <TextBlock x:Name="lblStage" Grid.Column="1" VerticalAlignment="Center"
                           FontSize="11" Opacity="0.5" Margin="12,0" />
                <ui:Button x:Name="btnDisconnect" Grid.Column="2" Content="Disconnect"
                           FontSize="12" IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>
</Page>
