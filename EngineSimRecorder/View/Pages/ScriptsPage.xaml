<Page x:Class="EngineSimRecorder.View.Pages.ScriptsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:EngineSimRecorder.Helpers"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  helpers:MouseWheelHelper.EnableForwarding="True">
        <StackPanel MinWidth="0" Margin="20,12,20,12">
            <TextBlock Text="Scripts" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="FMOD Studio scripts for your recording custom mod" FontSize="12" Opacity="0.6" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- FMOD Import Recordings Script -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Import Recordings to Events" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="fmod_import_recordings.js" FontSize="11" Opacity="0.4" FontFamily="Consolas" Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#2020FF20" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock Text="FMOD Studio" FontSize="10" FontWeight="SemiBold" Foreground="#80C080" />
                        </Border>
                    </Grid>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.6" Margin="0,0,0,10"
                               Text="Recursively imports .wav files from the Recordings/ folder into FMOD Studio, creates matching events under Events/Imported/, assigns them to the Master Bank, then saves and builds. Idempotent — safely skips files and events that already exist." />

                    <!-- Deploy to FMOD Project -->
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="12,10"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Deploy to FMOD Project" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.5" Margin="0,0,0,8"
                                       Text="Select your FMOD Studio project folder to install this script. It will appear under Scripts > Import Recordings to Events in FMOD Studio." />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" MinWidth="100" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Project:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                                <TextBox x:Name="txtFmodProjectDir" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                                <ui:Button x:Name="btnBrowseFmod" Grid.Column="2" Content="Browse" FontSize="12" Margin="8,0,0,0" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="lblDeployStatus" Grid.Column="0" FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
                                <ui:Button x:Name="btnDeploy" Grid.Column="1" Content="Deploy Script" Appearance="Primary" FontSize="12" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Recordings folder link -->
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="12,10"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Recordings Folder" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.5" Margin="0,0,0,8"
                                       Text="Copy your recorded .wav files to the Recordings/ folder inside your FMOD project directory. The script looks for files here when run." />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" MinWidth="100" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Output dir:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                                <TextBlock x:Name="lblRecordingsDir" Grid.Column="1" VerticalAlignment="Center" FontSize="12" Opacity="0.5"
                                           Text="(set an FMOD project above)" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                                <ui:Button x:Name="btnOpenRecordings" Grid.Column="2" Content="Open" FontSize="12" Margin="8,0,0,0" IsEnabled="False" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ui:Card>

            <!-- Script Preview -->
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Script Preview" FontSize="14" FontWeight="SemiBold" Grid.Column="0" />
                        <ui:Button x:Name="btnCopyScript" Grid.Column="1" Content="Copy to Clipboard" FontSize="11" />
                    </Grid>
                    <Border Background="#10101A" CornerRadius="6" Padding="12,10" MaxHeight="360">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBlock x:Name="txtScriptPreview"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#D4D4D4" TextWrapping="NoWrap"
                                       IsHitTestVisible="True" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ui:Card>

            <!-- How to Use -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="How to Use" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,6"
                                   Text="1. Record engine audio using the Recorder tab" />
                        <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,6" TextWrapping="Wrap"
                                   Text="2. Deploy this script to your FMOD project using the section above" />
                        <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,6" TextWrapping="Wrap"
                                   Text="3. Copy your recorded .wav files to the Recordings/ folder in your FMOD project" />
                        <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,6" TextWrapping="Wrap"
                                   Text="4. Open FMOD Studio → Scripts → Import Recordings to Events" />
                        <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,0" TextWrapping="Wrap"
                                   Text="5. The script will import audio, create events, assign to Master Bank, and build" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
