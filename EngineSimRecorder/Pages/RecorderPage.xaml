<Page x:Class="EngineSimRecorder.Pages.RecorderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="av"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid Margin="20,12,20,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header -->
                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,2">
                    <Run Text="E"/><Run Text="S Recorder"/>
                </TextBlock>
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,0,12">
                    <Run Text="Smart engine audio capture for Assetto Corsa"/>
                </TextBlock>

                <!-- ══ Process ══ -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Process" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Target:" Grid.Column="0" VerticalAlignment="Center"
                                       Opacity="0.6" FontSize="12" Margin="0,0,8,0" />
                            <ComboBox x:Name="cmbProcess" Grid.Column="1"
                                      IsEditable="False" VerticalAlignment="Center" FontSize="12" />
                            <ui:Button x:Name="btnRefresh" Grid.Column="2"
                                       Content="Connect" Appearance="Primary"
                                       Margin="8,0,0,0" FontSize="12" Click="btnRefresh_Click" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- ══ Output ══ -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Output" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Directory:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtOutputDir" Grid.Column="1"
                                     Text="recordings" VerticalAlignment="Center" FontSize="12" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                <ui:Button x:Name="btnBrowseOutput" Content="Browse…" FontSize="11" Click="btnBrowseOutput_Click" />
                                <ui:Button x:Name="btnOpenOutput" Content="&#x1F4C2;" Margin="4,0,0,0" FontSize="11" Click="btnOpenOutput_Click" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Car Name:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtCarName" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prefix:" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <TextBox x:Name="txtPrefix" Grid.Column="1" VerticalAlignment="Center" FontSize="12" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- ══ RPM Targets ══ -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="RPM Targets" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock x:Name="lblRedline" Text="" FontSize="11" FontWeight="Normal"
                                       Opacity="0.5" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- Preset chips -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Quick:" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.5" FontSize="11" />
                            <ui:Button Content="1K" FontSize="11" Padding="10,4" Click="btnPreset_Click" />
                            <ui:Button Content="2K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="3K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="4K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="5K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="6K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="7K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="8K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="9K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                            <ui:Button Content="10K" FontSize="11" Padding="10,4" Click="btnPreset_Click" Margin="3,0,0,0" />
                        </StackPanel>
                        <!-- List + Controls -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="lstTargetRpms" Grid.Column="0"
                                     FontFamily="Consolas" FontSize="11"
                                     SelectionChanged="lstTargetRpms_SelectionChanged"
                                     MouseDoubleClick="btnEditRpm_Click" Margin="0,0,0,0"
                                     MaxHeight="160" av:ItemsSource="{av:SampleData ItemCount=5}" />
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                                <TextBlock Text="Quick Edit" FontSize="10" Opacity="0.5" Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Content="-250" FontSize="11" Click="btnNudgeDown_Click" Width="60" />
                                    <ui:Button Content="+250" FontSize="11" Margin="3,0,0,0" Click="btnNudgeUp_Click" Width="60" />
                                    <ui:Button Content="Auto" FontSize="11" Margin="3,0,0,0" Click="btnSmartRpm_Click" Width="60" ToolTip="Auto-detect redline and fill RPM targets" />
                                </StackPanel>
                                <TextBlock Text="RPM value" FontSize="10" Opacity="0.5" Margin="0,10,0,4" />
                                <TextBox x:Name="txtRpmInput" Text="1000" Width="186" FontFamily="Consolas" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <ui:Button Content="Add" Appearance="Primary" FontSize="11" Click="btnAddRpm_Click" Width="92" />
                                    <ui:Button Content="Edit" FontSize="11" Margin="3,0,0,0" Click="btnEditRpm_Click" Width="91" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <ui:Button Content="Remove" FontSize="11" Click="btnRemoveRpm_Click" Width="92" />
                                    <ui:Button Content="Sort" FontSize="11" Margin="3,0,0,0" Click="btnSortRpm_Click" Width="91" />
                                </StackPanel>
                                <ui:Button Content="Clear All" FontSize="11" Margin="0,2,0,0" Click="btnClearRpm_Click" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- ══ Status ══ -->
                <ui:Card Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Status" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="lblStatus" Text="Idle..." VerticalAlignment="Center" FontSize="12" Opacity="0.6" Grid.Column="0" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="lblEta" Text="" VerticalAlignment="Center" FontSize="11" Opacity="0.5" Margin="0,0,8,0" />
                                <TextBlock x:Name="lblCurrentRpm" Text="RPM: ---" FontFamily="Consolas" FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                        <ProgressBar x:Name="pbarProgress" Height="5" Margin="0,6,0,0"
                                     Minimum="0" Maximum="1" Value="0" />
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ Actions (pinned bottom) ══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
            <ui:Button x:Name="btnStart" Content="&#x25B6;  Start"
                       Appearance="Success" FontSize="15" Padding="24,10" Click="btnStart_Click" />
            <ui:Button x:Name="btnStop" Content="&#x25A0;  Stop"
                       Appearance="Danger" FontSize="15" Padding="24,10" Margin="10,0,0,0"
                       IsEnabled="False" Click="btnStop_Click" />
            <CheckBox x:Name="chkStayOnTop" Content=" Stay on Top"
                      VerticalAlignment="Center" Margin="180,0,0,0" Opacity="0.6"
                      Checked="chkStayOnTop_Changed" Unchecked="chkStayOnTop_Changed" />
        </StackPanel>
    </Grid>
</Page>
