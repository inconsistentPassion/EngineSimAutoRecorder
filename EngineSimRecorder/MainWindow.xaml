<Window x:Class="EngineSimRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Engine Simulator Auto-Recorder 2.0 Alpha"
        Width="580
        " Height="740"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Slim modern scrollbar -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="4"
                                                        Background="#C0C0C0"
                                                        Margin="1,0" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SlimScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,10,20,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" ><Run Text="E"/><Run Language="en-ca" Text="S Recorder"/></TextBlock>
            <TextBlock
                       FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,1,0,0" ><Run Text="Automated engine audio capture"/><Run Language="en-ca" Text=" for Assetto Corsa"/></TextBlock>
        </StackPanel>

        <!-- ── Tab Control ── -->
        <TabControl Grid.Row="1" Margin="-20,0,-20,-6">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="12.5" />
                    <Setter Property="Padding" Value="12,6" />
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                </Style>
            </TabControl.Resources>

            <!-- ══ Tab 1: Recorder ══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Recorder" />
                </TabItem.Header>
                <Grid Margin="4,4,4,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Content (no scroll - everything fits) -->
                    <StackPanel Grid.Row="0">

                        <!-- ══ Process ══ -->
                        <GroupBox Margin="0,0,0,6">
                            <GroupBox.Header>
                                <TextBlock Text="▸  Process" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Target:" Grid.Column="0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                <ComboBox x:Name="cmbProcess" Grid.Column="1"
                                          IsEditable="False" VerticalAlignment="Center" FontSize="12" />
                                <Button x:Name="btnRefresh" Grid.Column="2"
                                        Content="Connect" Style="{StaticResource AccentButton}"
                                        Margin="6,0,0,0" FontSize="11.5" Click="btnRefresh_Click" />
                            </Grid>
                        </GroupBox>

                        <!-- ══ Output ══ -->
                        <GroupBox Margin="0,0,0,6">
                            <GroupBox.Header>
                                <TextBlock Text="▸  Output" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <Grid Margin="0,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Label Content="Directory:" Grid.Row="0" Grid.Column="0" FontSize="12" />
                                <TextBox x:Name="txtOutputDir" Grid.Row="0" Grid.Column="1"
                                         Text="recordings" VerticalAlignment="Center" FontSize="12" />
                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                    <Button x:Name="btnBrowseOutput" Content="Browse…"
                                            Style="{StaticResource FlatButton}" FontSize="11.5" Click="btnBrowseOutput_Click" />
                                    <Button x:Name="btnOpenOutput" Content="📂"
                                            Style="{StaticResource FlatButton}" Margin="4,0,0,0"
                                            Click="btnOpenOutput_Click" />
                                </StackPanel>

                                <Label Content="Car Name:" Grid.Row="1" Grid.Column="0" FontSize="12" />
                                <TextBox x:Name="txtCarName" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                         VerticalAlignment="Center" FontSize="12" />

                                <Label Content="Prefix:" Grid.Row="2" Grid.Column="0" FontSize="12" />
                                <TextBox x:Name="txtPrefix" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                         VerticalAlignment="Center" FontSize="12" />
                            </Grid>
                        </GroupBox>

                        <!-- ══ RPM Targets ══ -->
                        <GroupBox Margin="0,0,0,6">
                            <GroupBox.Header>
                                <TextBlock Text="▸  RPM Targets" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <StackPanel Margin="0,2">
                                <!-- Preset chips -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Quick:" VerticalAlignment="Center" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" />
                                    <Button Content="1K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" />
                                    <Button Content="2K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="3K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="4K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="5K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="6K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="7K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="8K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="9K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                    <Button Content="10K" Style="{StaticResource ChipButton}" Click="btnPreset_Click" Margin="3,0,0,0" />
                                </StackPanel>

                                <!-- List + Controls -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ListBox x:Name="lstTargetRpms" Grid.Column="0"
                                             FontFamily="Consolas" FontSize="11"
                                             BorderThickness="1" BorderBrush="{StaticResource ButtonBorderBrush}"
                                             SelectionChanged="lstTargetRpms_SelectionChanged"
                                             MouseDoubleClick="btnEditRpm_Click" Margin="0,10,0,0"
                                             MaxHeight="160" />

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                                        <!-- Quick adjust -->
                                        <TextBlock Text="Quick Edit" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2" />
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="-250" Style="{StaticResource FlatButton}" FontSize="11"
                                                    Click="btnNudgeDown_Click" Width="60" />
                                            <Button Content="+250" Style="{StaticResource FlatButton}" FontSize="11"
                                                    Margin="3,0,0,0" Click="btnNudgeUp_Click" Width="60" />
                                            <Button Content="⚡ Auto" Style="{StaticResource FlatButton}" FontSize="11"
                                                    Margin="3,0,0,0" Click="btnSmartRpm_Click" Width="60"
                                                    ToolTip="Auto-detect redline and fill RPM targets" />
                                        </StackPanel>

                                        <TextBlock Text="RPM value" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,2" />
                                        <TextBox x:Name="txtRpmInput" Text="1000" Width="142" FontFamily="Consolas" FontSize="12" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="Add" Style="{StaticResource AccentButton}" FontSize="11" Click="btnAddRpm_Click" Width="70" />
                                            <Button Content="Edit" Style="{StaticResource FlatButton}" FontSize="11" Margin="3,0,0,0" Click="btnEditRpm_Click" Width="70" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Button Content="Remove" Style="{StaticResource FlatButton}" FontSize="11" Click="btnRemoveRpm_Click" Width="70" />
                                            <Button Content="Sort" Style="{StaticResource FlatButton}" FontSize="11" Margin="3,0,0,0" Click="btnSortRpm_Click" Width="70" />
                                        </StackPanel>
                                        <Button Content="Clear All" Style="{StaticResource FlatButton}" FontSize="11" Margin="0,2,0,0" Click="btnClearRpm_Click" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- ══ Status ══ -->
                        <GroupBox Margin="0,0,0,0">
                            <GroupBox.Header>
                                <TextBlock Text="▸  Status" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <StackPanel Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="lblStatus" Text="Idle..."
                                               VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Grid.Column="0" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock x:Name="lblEta" Text=""
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0" />
                                        <TextBlock x:Name="lblCurrentRpm" Text="RPM: ---"
                                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar x:Name="pbarProgress" Height="5" Margin="0,4,0,0"
                                             Minimum="0" Maximum="1" Value="0"
                                             Foreground="{StaticResource AccentBrush}"
                                             Background="#E8E8E8" BorderThickness="0" />
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>

                    <!-- ══ Actions (pinned bottom) ══ -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,6">
                        <Button x:Name="btnStart" Content="▶  Start"
                                Style="{StaticResource BigStartButton}" Click="btnStart_Click" />
                        <Button x:Name="btnStop" Content="■  Stop"
                                Style="{StaticResource BigStopButton}" Margin="10,0,0,0"
                                IsEnabled="False" Click="btnStop_Click" />
                        <CheckBox x:Name="chkStayOnTop" Content=" Stay on Top"
                                  VerticalAlignment="Center" Margin="180,0,0,0"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  Checked="chkStayOnTop_Changed" Unchecked="chkStayOnTop_Changed" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ══ Tab 2: Log ══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Log" />
                </TabItem.Header>
                <Grid Margin="4,4,4,4">
                    <Border Background="{StaticResource LogBgBrush}"
                            CornerRadius="8" Padding="12,8">
                        <ScrollViewer Style="{StaticResource SlimScrollViewer}"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="txtLog"
                                     FontFamily="Cascadia Mono" FontSize="12"
                                     Foreground="{StaticResource LogTextBrush}"
                                     Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Disabled" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ Tab 3: Options ══ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Options" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4,4,4,4">
                    <StackPanel>

                        <!-- Profiles -->
                        <GroupBox>
                            <GroupBox.Header>
                                <TextBlock Text="▸  Profiles" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <StackPanel Margin="0,2">
                                <TextBlock Text="Save and load RPM target sets + output settings."
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />

                                <!-- Load -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Load:" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" />
                                    <ComboBox x:Name="cmbProfiles" Width="200" FontSize="12" />
                                    <Button Content="Load" Style="{StaticResource AccentButton}"
                                            FontSize="11" Margin="6,0,0,0" Click="btnLoadProfile_Click" />
                                    <Button Content="Delete" Style="{StaticResource FlatButton}"
                                            FontSize="11" Margin="3,0,0,0" Click="btnDeleteProfile_Click" />
                                </StackPanel>

                                <!-- Save -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Save:" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" />
                                    <TextBox x:Name="txtProfileName" Width="200" FontSize="12"
                                             VerticalAlignment="Center" />
                                    <Button Content="💾" Style="{StaticResource AccentButton}"
                                            FontSize="11" Margin="6,0,0,0" Click="btnSaveProfile_Click" />
                                </StackPanel>

                                <TextBlock x:Name="lblProfileStatus" Text="" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" />
                            </StackPanel>
                        </GroupBox>

                        <!-- ══ Recording Mode ══ -->
                        <GroupBox Margin="0,6,0,0">
                            <GroupBox.Header>
                                <TextBlock Text="▸  Recording Mode" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <StackPanel Margin="0,2">
                                <TextBlock Text="Interior mode applies a low-pass filter to simulate cabin sound."
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton x:Name="rbExterior" Content=" Exterior" IsChecked="True"
                                                 GroupName="RecMode" FontSize="12" Margin="0,0,20,0"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 Checked="rbMode_Checked" />
                                    <RadioButton x:Name="rbInterior" Content=" Interior (low-pass)"
                                                 GroupName="RecMode" FontSize="12"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 Checked="rbMode_Checked" />
                                </StackPanel>
                                <StackPanel x:Name="pnlCutoff" Margin="0,8,0,0" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Car type:" VerticalAlignment="Center" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" />
                                        <ComboBox x:Name="cmbCarType" Width="140" FontSize="12"
                                                  SelectionChanged="cmbCarType_SelectionChanged">
                                            <ComboBoxItem Content="Sedan" IsSelected="True" />
                                            <ComboBoxItem Content="Coupe" />
                                            <ComboBoxItem Content="SUV" />
                                            <ComboBoxItem Content="Hatchback" />
                                            <ComboBoxItem Content="Supercar" />
                                            <ComboBoxItem Content="Truck" />
                                            <ComboBoxItem Content="Custom" />
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Custom parameter sliders -->
                                    <Border x:Name="pnlCustom" Visibility="Collapsed"
                                            Background="#F8F8FA" CornerRadius="6" Padding="10,8" Margin="0,8,0,0"
                                            BorderBrush="#E0E0E4" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Cabin acoustics" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />

                                            <!-- LP Cutoff -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="LP cutoff" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slCutoff" Minimum="1000" Maximum="4000" Value="2000"
                                                        Width="140" TickFrequency="100" IsSnapToTickEnabled="True"
                                                        SmallChange="100" LargeChange="500" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblCutoff" Text="2000 Hz" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Rumble freq -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Rumble Hz" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slRumbleHz" Minimum="40" Maximum="120" Value="80"
                                                        Width="140" TickFrequency="5" IsSnapToTickEnabled="True"
                                                        SmallChange="5" LargeChange="20" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblRumbleHz" Text="80 Hz" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Rumble dB -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Rumble dB" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slRumbleDb" Minimum="0" Maximum="12" Value="6"
                                                        Width="140" TickFrequency="1" IsSnapToTickEnabled="True"
                                                        SmallChange="1" LargeChange="3" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblRumbleDb" Text="+6 dB" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Res 180 Hz -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Res 1 Hz" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slRes1Hz" Minimum="100" Maximum="300" Value="180"
                                                        Width="140" TickFrequency="10" IsSnapToTickEnabled="True"
                                                        SmallChange="10" LargeChange="50" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblRes1Hz" Text="180 Hz" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Res 1 dB" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slRes1Db" Minimum="0" Maximum="10" Value="5"
                                                        Width="140" TickFrequency="1" IsSnapToTickEnabled="True"
                                                        SmallChange="1" LargeChange="2" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblRes1Db" Text="+5 dB" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Res 350 Hz -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Res 2 Hz" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slRes2Hz" Minimum="200" Maximum="500" Value="350"
                                                        Width="140" TickFrequency="10" IsSnapToTickEnabled="True"
                                                        SmallChange="10" LargeChange="50" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblRes2Hz" Text="350 Hz" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Res 2 dB" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slRes2Db" Minimum="0" Maximum="8" Value="4"
                                                        Width="140" TickFrequency="1" IsSnapToTickEnabled="True"
                                                        SmallChange="1" LargeChange="2" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblRes2Db" Text="+4 dB" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <TextBlock Text="Stereo &amp; reverb" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,6" />

                                            <!-- Stereo width -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Width %" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slWidth" Minimum="10" Maximum="100" Value="30"
                                                        Width="140" TickFrequency="5" IsSnapToTickEnabled="True"
                                                        SmallChange="5" LargeChange="20" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblWidth" Text="30%" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Reverb mix -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Reverb %" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slReverbMix" Minimum="0" Maximum="20" Value="7"
                                                        Width="140" TickFrequency="1" IsSnapToTickEnabled="True"
                                                        SmallChange="1" LargeChange="5" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblReverbMix" Text="7%" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Reverb decay -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Rev ms" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slReverbMs" Minimum="10" Maximum="80" Value="30"
                                                        Width="140" TickFrequency="5" IsSnapToTickEnabled="True"
                                                        SmallChange="5" LargeChange="10" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblReverbMs" Text="30 ms" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <TextBlock Text="Dynamics" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,6" />

                                            <!-- Comp ratio -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Comp ratio" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slCompRatio" Minimum="1" Maximum="8" Value="3"
                                                        Width="140" TickFrequency="1" IsSnapToTickEnabled="True"
                                                        SmallChange="1" LargeChange="2" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblCompRatio" Text="3:1" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>

                                            <!-- Comp threshold -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="Threshold" Width="80" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                <Slider x:Name="slCompThresh" Minimum="-24" Maximum="0" Value="-12"
                                                        Width="140" TickFrequency="2" IsSnapToTickEnabled="True"
                                                        SmallChange="1" LargeChange="6" VerticalAlignment="Center"
                                                        ValueChanged="slCustom_ValueChanged" />
                                                <TextBlock x:Name="lblCompThresh" Text="-12 dB" Width="60" FontSize="11"
                                                           VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ══ Audio Quality ══ -->
                        <GroupBox Margin="0,6,0,0">
                            <GroupBox.Header>
                                <TextBlock Text="▸  Audio Quality" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <StackPanel Margin="0,2">
                                <TextBlock Text="Configure capture format. Changes apply to the next recording."
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Sample Rate:" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" />
                                    <ComboBox x:Name="cmbSampleRate" Width="120" FontSize="12" Margin="0,0,20,0">
                                        <ComboBoxItem Content="44100 Hz" IsSelected="True" />
                                        <ComboBoxItem Content="48000 Hz" />
                                    </ComboBox>
                                    <TextBlock Text="Channels:" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" />
                                    <ComboBox x:Name="cmbChannels" Width="100" FontSize="12" SelectionChanged="cmbChannels_SelectionChanged">
                                        <ComboBoxItem Content="Stereo" IsSelected="True" />
                                        <ComboBoxItem Content="Mono" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ══ Extras ══ -->
                        <GroupBox Margin="0,6,0,6">
                            <GroupBox.Header>
                                <TextBlock Text="▸  Extras" FontSize="12" FontWeight="SemiBold" />
                            </GroupBox.Header>
                            <StackPanel Margin="0,2">
                                <CheckBox x:Name="chkRecordLimiter" Content=" Record engine limiter sound at redline"
                                          FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                          Margin="0,0,0,4" />
                                <TextBlock Text="Records throttle held at redline (rev limiter). Output: engine_limiter.wav"
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                                <CheckBox x:Name="chkGeneratePowerLut" Content=" Generate power.lut (Assetto Corsa)"
                                          FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                          Margin="0,0,0,4" />
                                <TextBlock Text="Reads torque at each RPM target, outputs power.lut in N·m for AC."
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
