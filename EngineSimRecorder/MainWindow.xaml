<ui:FluentWindow x:Class="EngineSimRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:EngineSimRecorder.Pages"
        Title="Engine Simulator Auto-Recorder"
        Width="620" Height="700"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar x:Name="TitleBar"
                     Title="ES Recorder"
                     Grid.Row="0"
                     Icon="icon.ico" />

        <!-- Sidebar navigation -->
        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           IsTopSeparatorVisible="False"
                           IsFooterSeparatorVisible="False"
                           OpenPaneLength="180"
                           SelectionChanged="RootNavigation_SelectionChanged">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Recorder"
                                       Tag="recorder"
                                       TargetPageType="{x:Type pages:RecorderPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Record24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Log"
                                       Tag="log"
                                       TargetPageType="{x:Type pages:LogPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ClipboardCode24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Options"
                                       Tag="options"
                                       TargetPageType="{x:Type pages:OptionsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
