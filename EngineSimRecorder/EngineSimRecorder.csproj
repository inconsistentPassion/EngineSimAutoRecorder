<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>EngineSimRecorder</AssemblyName>
    <RootNamespace>EngineSimRecorder</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
  </PropertyGroup>

  <ItemGroup>
    <!-- NAudio: WASAPI loopback capture + FFT -->
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <!-- Auto-build es_hook.dll via CMake before C# compilation -->
  <PropertyGroup>
    <EngineSimHookBuildDir>$(MSBuildThisFileDirectory)..\EngineSimHook\build</EngineSimHookBuildDir>
    <EngineSimHookDll>$(MSBuildThisFileDirectory)..\EngineSimHook\bin\$(Configuration)\es_hook.dll</EngineSimHookDll>
    <VSWherePath>$([System.Environment]::ExpandEnvironmentVariables('%ProgramFiles(x86)%\Microsoft Visual Studio\Installer\vswhere.exe'))</VSWherePath>
  </PropertyGroup>

  <Target Name="BuildEngineSimHook" BeforeTargets="BeforeBuild"
          Inputs="..\EngineSimHook\CMakeLists.txt;..\EngineSimHook\src\dllmain.cpp;..\EngineSimHook\src\hooks.cpp;..\EngineSimHook\src\memory.cpp;..\EngineSimHook\src\pipe.cpp"
          Outputs="$(EngineSimHookDll)">
    <!-- Locate cmake.exe from the VS installation -->
    <Exec Command="&quot;$(VSWherePath)&quot; -latest -property installationPath"
 ConsoleToMSBuild="true"
          StandardOutputImportance="low">
      <Output TaskParameter="ConsoleOutput" PropertyName="_VSInstallDir" />
    </Exec>
    <PropertyGroup>
      <_CMakePath>$(_VSInstallDir)\Common7\IDE\CommonExtensions\Microsoft\CMake\CMake\bin\cmake.exe</_CMakePath>
    </PropertyGroup>
 <Message Importance="high" Text="=== Building es_hook.dll via CMake ===" />
 <Message Importance="high" Text="Using CMake: $(_CMakePath)" />
    <Exec Command="&quot;$(_CMakePath)&quot; -S &quot;$(MSBuildThisFileDirectory)..\EngineSimHook&quot; -B &quot;$(EngineSimHookBuildDir)&quot; -G &quot;Visual Studio 17 2022&quot; -A x64" />
    <Exec Command="&quot;$(_CMakePath)&quot; --build &quot;$(EngineSimHookBuildDir)&quot; --config $(Configuration)" />
    <Message Importance="high" Text="=== es_hook.dll built successfully ===" />
  </Target>

  <ItemGroup>
    <None Include="$(EngineSimHookDll)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Form1.cs">
  <SubType>Form</SubType>
  </Compile>
    <Compile Update="Form1.Designer.cs">
      <DependentUpon>Form1.cs</DependentUpon>
 <SubType>Code</SubType>
    </Compile>
  <EmbeddedResource Update="Form1.resx">
    <DependentUpon>Form1.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>

</Project>
